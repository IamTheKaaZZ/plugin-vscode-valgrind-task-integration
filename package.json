{
  "name": "valgrind-debug",
  "displayName": "Valgrind Debug",
  "description": "Debug C/C++ programs under Valgrind with a single launch configuration",
  "license": "MIT",
  "author": "IamTheKaaZZ",
  "publisher": "IamTheKaaZZ",
  "repository": {
    "type": "git",
    "url": "https://github.com/IamTheKaaZZ/plugin-vscode-valgrind-task-integration.git"
  },
  "bugs": {
    "url": "https://github.com/IamTheKaaZZ/plugin-vscode-valgrind-task-integration/issues"
  },
  "homepage": "https://github.com/IamTheKaaZZ/plugin-vscode-valgrind-task-integration#readme",
  "icon": "resources/icon.png",
  "version": "1.0.0",
  "engines": {
    "vscode": "^1.63.0"
  },
  "categories": [
    "Debuggers",
    "Programming Languages",
    "Other"
  ],
  "keywords": [
    "valgrind",
    "task",
    "launch",
    "cpp",
    "debug"
  ],
  "activationEvents": [
    "onDebugResolve:valgrind"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "configuration": {
      "title": "Valgrind",
      "properties": {
        "valgrind.binary": {
          "type": "string",
          "default": "valgrind",
          "description": "Path to the valgrind binary"
        },
        "valgrind.defaultArgs": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "--fullpath-after="
          ],
          "description": "Default valgrind arguments applied to all configurations"
        },
        "valgrind.debugger": {
          "type": "string",
          "enum": [
            "cppdbg",
            "codelldb"
          ],
          "default": "cppdbg",
          "description": "Default C++ debugger to use with Valgrind debug sessions"
        },
        "valgrind.pidTimeout": {
          "type": "number",
          "default": 30000,
          "description": "Timeout in ms to wait for the Valgrind process to report its PID"
        }
      }
    },
    "debuggers": [
      {
        "type": "valgrind",
        "label": "Valgrind",
        "languages": [
          "c",
          "cpp"
        ],
        "configurationAttributes": {
          "launch": {
            "required": [
              "program"
            ],
            "properties": {
              "program": {
                "type": "string",
                "description": "Path to the executable to debug under Valgrind"
              },
              "args": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "default": [],
                "description": "Arguments to pass to the target program"
              },
              "cwd": {
                "type": "string",
                "description": "Working directory for the program"
              },
              "valgrindArgs": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "default": [],
                "description": "Additional arguments for valgrind (e.g. --leak-check=full)"
              },
              "valgrindBinary": {
                "type": "string",
                "description": "Path to the valgrind binary (overrides valgrind.binary setting)"
              },
              "debugger": {
                "type": "string",
                "enum": [
                  "cppdbg",
                  "codelldb"
                ],
                "default": "cppdbg",
                "description": "The underlying C++ debugger to use"
              },
              "stopAtEntry": {
                "type": "boolean",
                "default": false,
                "description": "Stop at the entry point of the program"
              },
              "setupCommands": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "text": {
                      "type": "string"
                    },
                    "description": {
                      "type": "string"
                    },
                    "ignoreFailures": {
                      "type": "boolean"
                    }
                  },
                  "required": [
                    "text"
                  ]
                },
                "description": "Additional GDB setup commands (cppdbg only)"
              }
            }
          }
        },
        "configurationSnippets": [
          {
            "label": "Valgrind: Launch",
            "description": "Launch a program with Valgrind and the C++ debugger attached",
            "body": {
              "name": "Debug with Valgrind",
              "type": "valgrind",
              "request": "launch",
              "program": "^\"\\${workspaceFolder}/path/to/executable\"",
              "valgrindArgs": [
                "--leak-check=full"
              ]
            }
          }
        ]
      }
    ],
    "taskDefinitions": [
      {
        "type": "valgrind",
        "required": [
          "target"
        ],
        "properties": {
          "target": {
            "type": "string",
            "description": "Path to the executable to run under Valgrind"
          },
          "args": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Arguments to pass to the target program"
          },
          "valgrindArgs": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Additional arguments for valgrind"
          }
        }
      }
    ],
    "problemMatchers": [
      {
        "name": "valgrind",
        "owner": "cpp",
        "applyTo": "allDocuments",
        "fileLocation": "absolute",
        "source": "valgrind",
        "background": {
          "activeOnStart": true,
          "beginsPattern": "^==\\d+== Using Valgrind-[\\d\\.]+",
          "endsPattern": "^==\\d+== ERROR SUMMARY:"
        },
        "pattern": [
          {
            "regexp": "^==\\d+== ((?:Invalid|Syscall param|Conditional jump or move|Mismatched|Source and destination overlap|Argument) .+)$",
            "message": 1
          },
          {
            "regexp": "^==\\d+== \\s+(?:by|at).*\\((?:in )?([^:)]+)(?:\\:(\\d+))?\\)$",
            "file": 1,
            "line": 2,
            "loop": true
          }
        ]
      },
      {
        "name": "valgrind-debug",
        "base": "$valgrind",
        "background": {
          "activeOnStart": true,
          "beginsPattern": "^==\\d+== Using Valgrind-[\\d\\.]+",
          "endsPattern": "^==\\d+== TO DEBUG THIS PROCESS"
        }
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "webpack",
    "watch": "webpack --watch",
    "package": "webpack --mode production --devtool hidden-source-map",
    "test-compile": "tsc -p ./",
    "test-watch": "tsc -watch -p ./",
    "pretest": "npm run test-compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "node ./out/test/runTest.js",
    "test:unit": "npm run test-compile && mocha out/test/unit/**/*.test.js --require out/test/unit/setup.js --timeout 5000"
  },
  "devDependencies": {
    "@semantic-release/changelog": "^6.0.1",
    "@semantic-release/git": "^10.0.1",
    "@types/glob": "^7.2.0",
    "@types/mocha": "^9.1.1",
    "@types/node": "^18.0.0",
    "@types/proxyquire": "^1.3.31",
    "@types/sinon": "^21.0.1",
    "@types/vscode": "^1.53.0",
    "@typescript-eslint/eslint-plugin": "^5.28.0",
    "@typescript-eslint/parser": "^5.28.0",
    "eslint": "^8.18.0",
    "eslint-config-prettier": "^8.5.0",
    "glob": "^8.0.3",
    "mocha": "^10.0.0",
    "proxyquire": "^2.1.3",
    "semantic-release": "^19.0.3",
    "semantic-release-vsce": "^5.0.17",
    "sinon": "^21.1.2",
    "ts-loader": "^9.3.0",
    "typescript": "^4.7.4",
    "vscode-test": "^1.5.0",
    "webpack": "^5.73.0",
    "webpack-cli": "^4.10.0"
  },
  "release": {
    "branches": [
      "main",
      "develop"
    ],
    "verifyConditions": [
      "semantic-release-vsce",
      "@semantic-release/github"
    ],
    "prepare": {
      "path": "semantic-release-vsce",
      "packageVsix": true
    },
    "publish": [
      "semantic-release-vsce",
      {
        "path": "@semantic-release/github",
        "assets": "*.vsix"
      }
    ],
    "plugins": [
      "@semantic-release/commit-analyzer",
      "@semantic-release/release-notes-generator",
      "@semantic-release/changelog",
      [
        "@semantic-release/git",
        {
          "message": "chore(release): ${nextRelease.version}\n\n${nextRelease.notes}"
        }
      ],
      "@semantic-release/github"
    ]
  }
}
